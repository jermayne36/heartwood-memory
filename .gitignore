# Python/runtime noise
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.venv/

# JavaScript/runtime noise
node_modules/

# Local Heartwood runtime state used by .mcp.json and Docker volumes.
.heartwood/

# Local configuration and credentials. The root .mcp.json is the tracked,
# read-only starter template; keep credentials out of it.
.env*
.*-credentials*
.team-token*
.team-*-token*
/*.token
*.pem
*.p8
*.key
*.p12

# Root-local SQLite databases and their write-ahead-log sidecars.
/*.db
/*.db-wal
/*.db-shm

# Root-local memory exchange inputs and generated import reports.
/*.jsonl
/*-report.json

# Rotation demo output when a developer intentionally keeps a local receipt.
/examples/rotation-continuity/output*/
